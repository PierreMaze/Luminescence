  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 3000 && echo '[Press Ctrl + C] for EXIT 🛑",
    "build": "vite build",
    "lint": "echo 🎌 Checking Clean Code...🎌 && prettier --debug-check . && eslint --ext .js . && echo '----- Done!'",
