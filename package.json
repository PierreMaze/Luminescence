    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "postcss": "^8.4.40",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.6",
    "vite": "^5.3.4"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-CRLF"
  },
